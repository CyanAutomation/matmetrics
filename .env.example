# Vercel Blob Storage
# Get this token from your Vercel project dashboard
# https://vercel.com/dashboard/project/[project-name]/settings/storage
VERCEL_BLOB_READ_WRITE_TOKEN=

# Optional flag to disable Vercel Blob writes/reads at runtime.
# Default behavior (unset): true (Blob is enabled).
# Set to false to pause cloud persistence and keep data in local cache/sync queue until re-enabled.
ENABLE_VERCEL_BLOB=true

# Google Genai API
# Required for AI-powered technique suggestions and practice notes transformation
# Get your API key from: https://ai.google.dev/
GOOGLE_GENAI_API_KEY=
