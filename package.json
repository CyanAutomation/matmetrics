{
  "name": "nextn",
  "version": "1.2.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 9002",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "NODE_ENV=production next build --webpack",
    "start": "next start",
    "lint": "npm run validate:plugin-ui-contract && eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "rm -rf .next/types tsconfig.tsbuildinfo && next typegen && mkdir -p .next/types && printf 'export {};\n' > .next/types/cache-life.d.ts && tsc --noEmit --incremental false && prettier --check tsconfig.json",
    "test": "npm run validate:plugin-ui-contract && node --import tsx --test $(find plugins src -name '*.test.ts' ! -path 'src/lib/storage.test.ts') && node --import tsx src/lib/storage.test.ts",
    "test:all": "npm run validate:plugin-ui-contract && node --import tsx --test $(find plugins src -name '*.test.ts' ! -path 'src/lib/storage.test.ts') && node --import tsx src/lib/storage.test.ts",
    "go:build": "GOCACHE=/tmp/matmetrics-go-cache go build ./go/cmd/matmetrics-cli",
    "go:test": "GOCACHE=/tmp/matmetrics-go-cache go test ./internal/... ./go/... ./api/go/...",
    "verify": "npm test && npm run typecheck && npm run build && npm run go:test",
    "ci:contracts": "npm run validate:plugin-ui-contract && node --import tsx --test plugins/plugin-ui-contract-usage.test.ts plugins/plugin-ui-contract-composition-fixtures.test.ts src/lib/plugins/plugin-contract-gate.test.ts",
    "plugin:maturity:regenerate": "node --import tsx scripts/regenerate-plugin-maturity-scorecards.ts",
    "plugin:ui-migration:regenerate": "node --import tsx scripts/regenerate-plugin-ui-migration-scorecards.ts",
    "validate:plugin-ui-contract": "node --import tsx scripts/validate-plugin-ui-contract.ts",
    "validate:theme-contrast": "node scripts/check-theme-contrast.mjs"
  },
  "dependencies": {
    "@genkit-ai/google-genai": "^1.28.0",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "genkit": "^1.28.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.475.0",
    "next": "16.2.3",
    "next-themes": "^0.4.4",
    "patch-package": "^8.0.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.7",
    "genkit-cli": "^1.28.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
